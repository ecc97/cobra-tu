# =========================
# Variables de entorno (ejemplo)
# =========================

# --- OpenRouter (server-side) -------------------------------------------
# Clave y endpoint para llamadas desde el servidor. NO exponer la API key
# en el frontend (no usar NEXT_PUBLIC_ para la API key en producción).
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_API_MODEL=your_model_name_here

# Si por algún motivo necesitas acceder desde el cliente, añade la
# variable pública (NO recomendado para claves sensibles):
# NEXT_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here

# ------------------------
# Notas:
# - Rellena solo las variables necesarias antes de desplegar.
# - Reinicia el servidor tras cambiar variables de entorno.
# ------------------------
